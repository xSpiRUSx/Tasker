# Tasker model/runtime selection
#
# Copy to .env for local overrides. Do not put credentials here.

# Model policy profile: cheap, balanced, quality, mock.
TASKER_MODEL_PROFILE=balanced

# Main reasoning model used by configured gpt55_* targets.
TASKER_GPT55_MODEL=gpt-5.5

# Cheaper Codex model used by micro-corrections.
TASKER_CODEX_SPARK_MODEL=gpt-5.3-codex-spark

# Optional router-specific override. Defaults to TASKER_GPT55_MODEL when unset.
TASK_ROUTER_MODEL=

TASKER_CHEAP_CLASSIFIER_MODEL=

# Existing runtime switches.
ORCHESTRATOR_ROUTER_PROVIDER=codex-cli
ORCHESTRATOR_PLANNER_PROVIDER=codex-cli
ORCHESTRATOR_DEFAULT_EXECUTOR=codex
ORCHESTRATOR_CODEX_BIN=codex

# Optional direct legacy overrides. Prefer model_policy.yml for new behavior.
ORCHESTRATOR_PLANNER_MODEL=
ORCHESTRATOR_CODEX_MODEL=
