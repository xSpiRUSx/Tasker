# Default mode uses local Codex CLI auth. Run `codex login` once before using it.
TASK_ROUTER_PROVIDER=codex-cli

# Optional: override config directory containing projects.yml and workflows.yml.
TASK_ROUTER_CONFIG_DIR=

# Optional: path/name of the Codex executable.
TASK_ROUTER_CODEX_BIN=codex

# Optional: override the model used by `codex exec`.
# Leave empty to use your Codex config/default.
TASK_ROUTER_CODEX_MODEL=

# Optional fallback provider: set TASK_ROUTER_PROVIDER=openai-api and provide OPENAI_API_KEY.
OPENAI_API_KEY=
TASK_ROUTER_MODEL=gpt-5.5

# Use 1 for local dry-runs without an API call.
TASK_ROUTER_MOCK_LLM=0
