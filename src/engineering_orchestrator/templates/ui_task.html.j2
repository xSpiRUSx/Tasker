<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ task.id }}</title>
  <style>
    :root { color-scheme: light; --line: #d8dee8; --ink: #17202a; --muted: #5d6b7a; --fill: #f6f8fb; --accent: #0f766e; --bad: #b42318; }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: Segoe UI, Arial, sans-serif; color: var(--ink); background: #fff; }
    header { border-bottom: 1px solid var(--line); padding: 14px 22px; display: flex; align-items: center; justify-content: space-between; gap: 14px; }
    main { padding: 20px 22px; max-width: 1180px; margin: 0 auto; }
    h1 { font-size: 22px; margin: 0; font-weight: 650; }
    h2 { font-size: 15px; margin: 22px 0 8px; text-transform: uppercase; color: var(--muted); letter-spacing: .03em; }
    a { color: #0f5f96; }
    button, a.button { min-height: 34px; border: 1px solid var(--accent); background: var(--accent); color: #fff; border-radius: 6px; padding: 0 12px; text-decoration: none; display: inline-flex; align-items: center; cursor: pointer; }
    button.reject { border-color: var(--bad); background: var(--bad); }
    input { height: 34px; border: 1px solid var(--line); border-radius: 6px; padding: 0 10px; min-width: 260px; }
    table { width: 100%; border-collapse: collapse; table-layout: fixed; }
    th, td { border-bottom: 1px solid var(--line); padding: 10px 8px; text-align: left; vertical-align: top; font-size: 14px; }
    th { background: var(--fill); font-size: 12px; text-transform: uppercase; color: var(--muted); letter-spacing: .02em; }
    code { font-family: Consolas, monospace; font-size: 13px; }
    .grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
    .metric { border-bottom: 1px solid var(--line); padding: 8px 0; min-width: 0; }
    .label { font-size: 12px; color: var(--muted); text-transform: uppercase; margin-bottom: 4px; }
    .value { overflow-wrap: anywhere; }
    .actions { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
    .muted { color: var(--muted); }
    @media (max-width: 760px) { .grid { grid-template-columns: 1fr 1fr; } header { align-items: flex-start; flex-direction: column; } }
  </style>
</head>
<body>
  <header>
    <h1><code>{{ task.id }}</code></h1>
    <a class="button" href="/ui/tasks">Tasks</a>
  </header>
  <main>
    <section class="grid">
      <div class="metric"><div class="label">Status</div><div class="value"><code>{{ task.status }}</code></div></div>
      <div class="metric"><div class="label">Project</div><div class="value"><code>{{ task.project_id or "unknown" }}</code></div></div>
      <div class="metric"><div class="label">Workflow</div><div class="value"><code>{{ task.workflow_id or "unknown" }}</code></div></div>
      <div class="metric"><div class="label">Risk</div><div class="value"><code>{{ task.risk_level or "unknown" }}</code></div></div>
    </section>

    <h2>Request</h2>
    <p>{{ task.user_message }}</p>

    <h2>Pending Approvals</h2>
    <div class="actions">
      {% for approval in pending %}
        <code>{{ approval.gate }}</code>
        <button type="button" onclick="decide('{{ approval.gate }}', 'approve')">Approve {{ approval.gate }}</button>
        <input id="comment-{{ approval.gate }}" placeholder="comment">
        <button type="button" class="reject" onclick="decide('{{ approval.gate }}', 'reject')">Reject {{ approval.gate }}</button>
      {% else %}
        <span class="muted">None.</span>
      {% endfor %}
    </div>

    <h2>Artifacts</h2>
    <table>
      <thead><tr><th style="width: 190px;">Kind</th><th>Title</th><th style="width: 90px;">Version</th><th>Path</th></tr></thead>
      <tbody>
        {% for artifact in artifacts %}
        <tr>
          <td><code>{{ artifact.kind }}</code></td>
          <td>{{ artifact.title }}</td>
          <td>{{ artifact.version or "" }}</td>
          <td><code>{{ artifact.relative_path }}</code></td>
        </tr>
        {% else %}
        <tr><td colspan="4" class="muted">No artifacts.</td></tr>
        {% endfor %}
      </tbody>
    </table>

    <h2>Events</h2>
    <table>
      <thead><tr><th style="width: 230px;">Time</th><th style="width: 240px;">Type</th><th>Payload</th></tr></thead>
      <tbody>
        {% for event in events %}
        <tr>
          <td class="muted">{{ event.created_at }}</td>
          <td><code>{{ event.event_type }}</code></td>
          <td><code>{{ event.payload }}</code></td>
        </tr>
        {% else %}
        <tr><td colspan="3" class="muted">No events.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </main>
  <script>
    async function decide(gate, decision) {
      const input = document.getElementById(`comment-${gate}`);
      const comment = input ? input.value : "";
      const response = await fetch(`/tasks/{{ task.id }}/approvals/${gate}`, {
        method: "POST",
        headers: {"Content-Type": "application/json"},
        body: JSON.stringify({decision, comment})
      });
      if (!response.ok) {
        alert(await response.text());
        return;
      }
      window.location.reload();
    }
  </script>
</body>
</html>
